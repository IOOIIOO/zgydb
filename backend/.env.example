# ============================================
# Career Planning System — 环境变量模板
# 复制此文件为 .env 并修改为实际值
# ============================================

# 调试模式 (true/false)
DEBUG=true

# 数据库连接 (MySQL)
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/career_planning

# JWT 密钥 (生产环境请更换为随机字符串)
SECRET_KEY=change-me-to-a-random-string-in-production

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 文件上传目录
UPLOAD_DIR=uploads

# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE_MB=10

# 报告存储目录
REPORT_DIR=reports

# CORS 允许的前端地址（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173

# 模型模式: fake（假数据）| real（真实模型）
MODEL_MODE=fake
